        "@codemirror/view": "^6.43.1",
        "buffer": "^6.0.3",
        "codemirror": "^6.0.2",
        "css-color-converter": "^2.0.0",
        "debug": "^4.4.3",
        "diff": "^9.0.0",
        "diff2html": "^3.4.56",
